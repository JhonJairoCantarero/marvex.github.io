---
// ThemeToggle.astro
---

<button id="theme-toggle" class="theme-toggle" aria-label="Cambiar tema">
    <svg
        class="sun-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>
    <svg
        class="moon-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
</button>

<style>
    .theme-toggle {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 1000;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        color: var(--color-text);
        width: 3rem;
        height: 3rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: var(--shadow-lg);
        transition: all 0.3s ease;
        padding: 0;
    }

    .theme-toggle:hover {
        transform: scale(1.1);
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    .sun-icon,
    .moon-icon {
        position: absolute;
        transition:
            transform 0.5s ease,
            opacity 0.5s ease;
    }

    /* Logic for showing icons based on theme */
    :global([data-theme="dark"]) .sun-icon {
        opacity: 1;
        transform: rotate(0deg);
    }

    :global([data-theme="dark"]) .moon-icon {
        opacity: 0;
        transform: rotate(90deg);
    }

    :global([data-theme="light"]) .sun-icon {
        opacity: 0;
        transform: rotate(-90deg);
    }

    :global([data-theme="light"]) .moon-icon {
        opacity: 1;
        transform: rotate(0deg);
    }

    /* Default state (no data-theme) - assumes system preference or default dark */
    /* If system is light, show moon. If system is dark, show sun. */
    @media (prefers-color-scheme: light) {
        :global(:root:not([data-theme="dark"])) .sun-icon {
            opacity: 0;
            transform: rotate(-90deg);
        }
        :global(:root:not([data-theme="dark"])) .moon-icon {
            opacity: 1;
            transform: rotate(0deg);
        }
    }

    @media (prefers-color-scheme: dark) {
        :global(:root:not([data-theme="light"])) .sun-icon {
            opacity: 1;
            transform: rotate(0deg);
        }
        :global(:root:not([data-theme="light"])) .moon-icon {
            opacity: 0;
            transform: rotate(90deg);
        }
    }
</style>

<script>
    const themeToggle = document.getElementById("theme-toggle");

    const getTheme = () => {
        if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
        ) {
            return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: light)").matches) {
            return "light";
        }
        return "dark";
    };

    const setTheme = (theme) => {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem("theme", theme);
    };

    // Initialize
    // Note: The main initialization happens in Layout.astro to prevent FOUC
    // This script handles the button click

    themeToggle?.addEventListener("click", () => {
        const currentTheme = getTheme();
        const newTheme = currentTheme === "light" ? "dark" : "light";
        setTheme(newTheme);
    });
</script>
