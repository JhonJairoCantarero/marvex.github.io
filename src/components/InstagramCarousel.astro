---
// Componente de carrusel simplificado tipo Instagram
// Props:
// - images: string[] URLs o rutas locales
// - avatarSrc: string URL del avatar
// - avatarAlt: string alt del avatar
// - title: string título del header
export interface Props {
  images: string[];
  avatarSrc?: string;
  avatarAlt?: string;
  title?: string;
}

const {
  images = [],
  avatarSrc = "/favicon.png",
  avatarAlt = "Marvex Icon",
  title = "Marvex",
} = Astro.props;
const totalItems = images.length;

function getDelayStyle(index: number, total: number): string {
  const delayPerItem = 8 / Math.max(1, total);
  return `animation-delay: calc(${delayPerItem}s * ${index})`;
}
---

<!-- Contenedor principal simplificado -->
<div class="instagram-carousel-wrapper">
  <div class="container">
    <aside class="carousel" aria-hidden="true">
      <div class="carousel__wrapper">
        {
          images.map((item, i) => (
            <div
              class="item"
              id={`slide-${i}`}
              style={getDelayStyle(i, totalItems)}
            >
              <img
                src={item}
                alt=""
                width="418"
                height="418"
                loading={i < 2 ? "eager" : "lazy"}
              />
            </div>
          ))
        }
      </div>
    </aside>
    <article class="instagram" aria-label="Carrusel Marvex">
      <header class="instagram__header">
        <figure>
          {
            avatarSrc && (
              <img src={avatarSrc} alt={avatarAlt} width="42" height="42" />
            )
          }
          <figcaption>
            <h4>{title}</h4>
          </figcaption>
        </figure>
      </header>
      <section class="instagram__media">
        <div class="img">
          <!-- Carrusel simplificado -->
          <div class="media-carousel">
            {
              images.map((item, i) => (
                <div class="media-item" id={`media-slide-${i}`}>
                  <img
                    src={item}
                    alt={`Porcelanato Marvex ${i + 1}`}
                    loading={i < 2 ? "eager" : "lazy"}
                  />
                </div>
              ))
            }
          </div>

          <!-- Fallback si no hay imágenes -->
          {
            images.length === 0 && (
              <div class="media-fallback">
                <span>✨ Marvex Porcelanato ✨</span>
              </div>
            )
          }
        </div>
      </section>
      <footer class="instagram__buttons" aria-hidden="true">
        <div class="left">
          <svg
            class="instagram__icon instagram__icon--heart"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M16.8196 3.40477L16.8196 3.40468L16.8105 3.40435C15.9939 3.37401 15.1837 3.55848 14.4607 3.93934C13.7415 4.31818 13.1337 4.87813 12.6974 5.56376C12.3799 6.0141 12.1595 6.38237 12.0011 6.66645C11.841 6.38254 11.6182 6.01451 11.2971 5.5646C10.8588 4.88294 10.252 4.32584 9.53521 3.94728C8.81455 3.56666 8.00746 3.37954 7.19284 3.40423L7.19283 3.40408L7.18038 3.40477C5.73422 3.48471 4.37827 4.133 3.40801 5.20836C2.44041 6.28078 1.93462 7.69124 1.99999 9.13385C2.00344 10.8131 2.73878 12.1587 3.76066 13.3486C4.54375 14.2605 5.52952 15.1172 6.516 15.9745C6.80035 16.2216 7.08476 16.4688 7.36439 16.7173C7.71256 17.0283 8.0484 17.3289 8.36875 17.6156C9.03981 18.2163 9.64287 18.7561 10.1488 19.2024C10.8808 19.8482 11.4505 20.3358 11.7281 20.5156L11.9996 20.6915L12.2713 20.516C12.5291 20.3494 13.0097 19.9415 13.7041 19.3303C14.2257 18.8712 14.8883 18.2789 15.7018 17.5517C15.9935 17.2909 16.3047 17.0128 16.6357 16.7172C16.9253 16.4597 17.2205 16.2037 17.5157 15.9477C18.4876 15.105 19.4601 14.2617 20.2346 13.3628C21.2586 12.1744 21.9965 10.8264 22 9.13385C22.0653 7.69123 21.5596 6.28078 20.592 5.20836C19.6217 4.133 18.2657 3.48471 16.8196 3.40477ZM11.6142 4.35506L11.9954 4.80294L12.3761 4.35467C12.9155 3.71951 13.5913 3.21422 14.3531 2.87644C15.1144 2.53889 15.9419 2.37731 16.7742 2.40369C18.4866 2.47112 20.1027 3.21362 21.2694 4.46897C22.4364 5.72476 23.0588 7.39158 23.0003 9.10494L23 9.11347V9.122C23 12.4787 20.5608 14.6294 18.1924 16.6842C17.8966 16.94 17.598 17.2003 17.3031 17.462L17.3018 17.4632L16.3798 18.2872L16.3736 18.2927L16.3676 18.2985C15.2327 19.3827 14.0415 20.4065 12.7991 21.3656C12.5599 21.5162 12.2829 21.5962 12 21.5962C11.7171 21.5962 11.4402 21.5162 11.201 21.3657C9.9972 20.4352 8.84189 19.4436 7.73965 18.3948L7.73401 18.3894L7.7282 18.3842L6.7012 17.4662L6.70057 17.4657C6.43759 17.2314 6.17305 17.0015 5.91337 16.7758C5.88988 16.7554 5.86643 16.735 5.84303 16.7147C3.34442 14.5424 0.999982 12.4694 0.999982 9.122V9.11347L0.999691 9.10494C0.941196 7.39158 1.56352 5.72476 2.73058 4.46897C3.89709 3.21378 5.51295 2.47131 7.2251 2.40372C8.0557 2.37962 8.88112 2.54227 9.6405 2.87968C10.4006 3.21742 11.0751 3.72163 11.6142 4.35506Z"
            ></path>
          </svg>
          <svg
            class="instagram__icon instagram__icon--comment"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M20.656 17.008C21.8711 14.9061 22.2795 12.4337 21.8048 10.0527C21.3301 7.67172 20.0048 5.54497 18.0765 4.06978C16.1482 2.59458 13.7488 1.87186 11.3266 2.0366C8.9043 2.20135 6.62486 3.24231 4.91408 4.96501C3.20329 6.68772 2.17817 8.97432 2.03024 11.3977C1.8823 13.821 2.62166 16.2153 4.1102 18.1334C5.59874 20.0514 7.73463 21.3619 10.1189 21.82C12.5031 22.2782 14.9726 21.8527 17.066 20.623L22 22L20.656 17.008Z"
            ></path>
          </svg>
          <svg
            class="instagram__icon instagram__icon--message"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M22 3 9.218 10.083M11.698 20.334 22 3.001H2L9.218 10.084 11.698 20.334Z"
            ></path>
          </svg>
        </div>
        <div class="right">
          <svg
            class="instagram__icon instagram__icon--saved"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M20 21L12 13.44L4 21V3H20V21Z"></path>
          </svg>
        </div>
      </footer>
    </article>
  </div>
</div>

<style>
  * {
    box-sizing: border-box;
  }

  /* Contenedor principal simplificado */
  .instagram-carousel-wrapper {
    position: relative;
    width: 100%;
    min-height: 60vh;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 0;
  }

  /* Contenedor del carrusel */
  .container {
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    max-width: 500px;
  }

  /* Carrusel de fondo simplificado */
  .carousel {
    position: absolute;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .carousel__wrapper {
    position: relative;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .carousel .item {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1s ease-in-out;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 8px 25px var(--shadow-lg);
  }

  .carousel img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 15px;
  }

  .carousel .item.active {
    opacity: 0.3;
  }

  .instagram {
    width: 100%;
    max-width: 400px;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    color: var(--color-text);
    background: var(--color-surface);
    box-shadow: var(--shadow-xl);
    z-index: 2;
    overflow: hidden;
  }

  .instagram__header {
    padding-block: 12px;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .instagram__header figure {
    padding-inline: 16px;
    margin: 0;
    display: flex;
    align-items: center;
  }

  .instagram__header img {
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-primary);
    margin-inline-end: 8px;
  }

  .instagram__header h4 {
    color: var(--color-text);
    font-weight: 600;
    margin: 0;
    font-family: var(--font-body);
  }

  .instagram__media {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .instagram__media .img {
    width: 100%;
    aspect-ratio: 16/9; /* Cambiado de 1/1 a 16/9 para imágenes más grandes */
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    font-size: 1.2rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  /* Carrusel de media simplificado */
  .media-carousel {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .media-item {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1s ease-in-out;
    display: flex;
    align-items: center;
    justify-content: center;
    top: 0;
    left: 0;
    background: var(--color-surface);
    overflow: hidden;
  }

  .media-item.active {
    opacity: 1;
  }

  .media-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Fallback para cuando no hay imágenes */
  .media-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    text-align: center;
  }

  .instagram__buttons {
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--color-surface);
  }

  .instagram__buttons .left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .instagram__icon {
    width: 24px;
    height: 24px;
    transition: all 0.3s ease;
  }

  .instagram__icon:hover {
    opacity: 0.7;
    transform: scale(1.1);
  }

  .instagram__icon path {
    stroke: var(--color-primary);
    stroke-linejoin: round;
    fill: none;
    stroke-width: 2;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .instagram-carousel-wrapper {
      min-height: 50vh;
      padding: 1rem 0;
    }

    .instagram {
      max-width: 350px;
    }

    .instagram__media .img {
      aspect-ratio: 4/3;
    }
  }
</style>

<script>
  // Carrusel simple y funcional
  document.addEventListener("DOMContentLoaded", () => {
    const mediaItems = document.querySelectorAll(".media-item");
    const carouselItems = document.querySelectorAll(".carousel .item");
    let currentIndex = 0;

    if (mediaItems.length === 0) return;

    // Función para mostrar una imagen específica
    function showImage(index) {
      // Ocultar todas las imágenes
      mediaItems.forEach((item, i) => {
        item.classList.toggle("active", i === index);
      });

      carouselItems.forEach((item, i) => {
        item.classList.toggle("active", i === index);
      });
    }

    // Mostrar la primera imagen
    showImage(0);

    // Cambiar imagen automáticamente cada 4 segundos
    setInterval(() => {
      currentIndex = (currentIndex + 1) % mediaItems.length;
      showImage(currentIndex);
    }, 4000);

    // Permitir navegación manual al hacer clic en las imágenes
    mediaItems.forEach((item, index) => {
      item.addEventListener("click", () => {
        currentIndex = index;
        showImage(currentIndex);
      });
    });
  });
</script>
